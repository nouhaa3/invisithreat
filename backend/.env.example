# Backend Environment Variables
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit .env to version control

# Application
APP_NAME=InvisiThreat
APP_VERSION=0.1.0
ENVIRONMENT=development

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database - Use strong passwords in production
DATABASE_URL=postgresql://invisithreat:invisithreat_password@db:5432/invisithreat_db
POSTGRES_DB=invisithreat_db
POSTGRES_USER=invisithreat
POSTGRES_PASSWORD=invisithreat_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=

# Frontend
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email Service (Brevo/SendinBlue)
BREVO_API_KEY=
ADMIN_EMAIL=
PRIMARY_ADMIN_EMAIL=invisithreat@gmail.com

# SMTP Configuration (fallback)
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# GitHub Integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_TOKEN=
