# ===============================
# InvisiThreat Environment Config
# ===============================

# App
APP_NAME=InvisiThreat
APP_VERSION=0.1.0
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=CHANGE_THIS_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# Option A (recommended for a shared cloud DB, e.g. Supabase):
# Leave empty to use POSTGRES_* fallback values below.
DATABASE_URL=
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres
# POSTGRES_SSLMODE=require
#
# Option B (local Docker DB):
POSTGRES_DB=invisithreat_db
POSTGRES_USER=invisithreat
POSTGRES_PASSWORD=invisithreat_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=

# CORS
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email (Brevo)
BREVO_API_KEY=
EMAIL_FROM=sender@example.com
PRIMARY_ADMIN_EMAIL=invisithreat@gmail.com
ADMIN_EMAIL=admin@example.com

# SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
