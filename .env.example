# ===============================
# InvisiThreat Environment Config
# ===============================

# App
APP_NAME=InvisiThreat
APP_VERSION=0.1.0
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=CHANGE_THIS_SECRET_KEY
ENCRYPTION_KEY=CHANGE_ME_GENERATE_ENCRYPTION_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Database
# Option A (recommended for Supabase / shared DB)
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres
# POSTGRES_SSLMODE=require

# Option B (local Docker DB)
DATABASE_URL=postgresql://invisithreat:invisithreat_password@db:5432/invisithreat_db
POSTGRES_SSLMODE=

# CORS
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email (Brevo)
BREVO_API_KEY=
EMAIL_FROM=
PRIMARY_ADMIN_EMAIL=
ADMIN_EMAIL=

# SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# LLM (Ollama)
FEATURE_AI_ENABLED=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_SECONDS=0.75

# GitHub Integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/github/oauth/callback
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_TOKEN=