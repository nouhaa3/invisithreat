@startuml DS-3a
skinparam sequenceMessageAlign left
skinparam maxMessageSize 160
title DS-3a : Moteur SAST\n(Lancement scan · Exécution Celery · Suivi Socket.IO temps réel)

actor       "Developer"                         as DEV
boundary    "ScanForm\n(NewScanPage)"            as SCAN_UI
boundary    "ScanProgressUI\n(ProjectDetail)"    as SIO_CLIENT
control     "ScanController"                     as SCAN_CTRL
control     "CeleryWorker\n(run_github_scan_job)" as WORKER
control     "SocketIOGateway"                    as SIO_GW
control     "NotificationService"                as NOTIF
entity      "Scan"                               as SCAN_E
entity      "Vulnerability"                      as VULN_E
database    "PostgreSQL"                         as DB
queue       "Redis Queue"                        as REDIS

== Lancement du scan SAST ==
DEV      ->  SCAN_UI   : soumettre(projectId, type="sast", branch)
SCAN_UI  ->  SCAN_CTRL : POST /projects/{id}/scans(ScanCreate)
activate SCAN_CTRL
SCAN_CTRL -> SCAN_CTRL : checkPermission(user, projectId): None
alt permission refusée
    SCAN_CTRL --> SCAN_UI : 403 "Accès refusé"
    SCAN_UI   --> DEV     : afficher(erreur)
else permission accordée
    SCAN_CTRL -> SCAN_E   : save(scan{type:"sast", status:"pending"}): Scan
    activate SCAN_E
    SCAN_E    -> DB       : INSERT INTO scans
    DB        --> SCAN_E  : scanId
    SCAN_E    --> SCAN_CTRL : pendingScan
    deactivate SCAN_E
    SCAN_CTRL -> REDIS    : enqueue(run_github_scan_job, scanId): taskId
    activate REDIS
    REDIS     --> SCAN_CTRL : taskId
    deactivate REDIS
    SCAN_CTRL --> SCAN_UI : 201 ScanResponse(id, status="pending")
    SCAN_UI   --> DEV     : rediriger("/project/{id}")
end
deactivate SCAN_CTRL

== Exécution asynchrone (Celery Worker) ==
REDIS -> WORKER : dequeue(scanId): void
activate WORKER
WORKER -> SCAN_E : updateStatus(scanId, status="running"): Scan
activate SCAN_E
SCAN_E -> DB     : UPDATE scans SET status="running"
DB     --> SCAN_E : ok
SCAN_E --> WORKER : ok
deactivate SCAN_E
WORKER -> SIO_GW : emit("scan_progress", {scanId, step:"clone", pct:10})
activate SIO_GW
SIO_GW --> SIO_CLIENT : broadcast("scan_progress", payload)
SIO_CLIENT --> DEV    : afficher(barre 10%)
deactivate SIO_GW
WORKER -> WORKER : cloneRepository(repoUrl, decryptedToken): Path
WORKER -> SIO_GW : emit("scan_progress", {scanId, step:"analyze", pct:50})
activate SIO_GW
SIO_GW --> SIO_CLIENT : broadcast("scan_progress", payload)
SIO_CLIENT --> DEV    : afficher(barre 50%)
deactivate SIO_GW
WORKER -> WORKER : runSASTTools(path): List[Finding]
WORKER -> WORKER : normalizeFindings(findings): List[Vulnerability]
loop pour chaque vulnérabilité normalisée
    WORKER -> VULN_E : save(vuln{scanId, severity, file, line}): Vulnerability
    activate VULN_E
    VULN_E -> DB     : INSERT INTO vulnerabilities
    DB     --> VULN_E : ok
    VULN_E --> WORKER : ok
    deactivate VULN_E
end
WORKER -> SCAN_E : updateStatus(scanId, "completed", vulnCount): Scan
activate SCAN_E
SCAN_E -> DB     : UPDATE scans SET status="completed"
DB     --> SCAN_E : ok
SCAN_E --> WORKER : ok
deactivate SCAN_E
WORKER -> SIO_GW : emit("scan_completed", {scanId, vulnCount})
activate SIO_GW
SIO_GW --> SIO_CLIENT : broadcast("scan_completed", payload)
SIO_CLIENT --> DEV    : notification("Scan terminé — N vulnérabilités")
deactivate SIO_GW
WORKER -> NOTIF  : notifyScanCompleted(userId, scanId): void
activate NOTIF
NOTIF  --> WORKER : ok
deactivate NOTIF
deactivate WORKER

@enduml
