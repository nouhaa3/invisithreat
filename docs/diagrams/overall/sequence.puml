@startuml
title Workflow global - Connexion vers toutes les features
actor "Utilisateur" as U
actor "Security Manager" as SEC
boundary "IHM Web" as UI
control "AuthController" as AC
control "TOTPController" as TC
control "SessionManager" as SMGR
control "AuditLogService" as ALS
control "ProjectController" as PC
control "ProjectService" as PS
control "IntegrationsController" as IC
control "APIKeyController" as AKC
control "ScanController" as SC
control "DastController" as DC
control "DashboardController" as DBC
control "WorkflowController" as WC
control "NotificationService" as NS
control "SocketIOManager" as WS
control "CeleryWorker" as CW
control "GitHubScannerService" as GS
control "DependencyScanner" as DS
control "DastScannerService" as DASTS
control "RiskScoreService" as RS
control "VulnWorkflowService" as VWS
control "ScanSummaryCache" as SSC
entity "UserModel" as UM
entity "ProjectModel" as PM
entity "ScanModel" as SCM
entity "GitHubRepositoryModel" as GR
entity "APIKeyModel" as AKM
entity "VulnerabilityTaskModel" as VTM
entity "RiskScoreModel" as RSM
database "Base de donnees" as DB
participant "GitHub OAuth" as GHO
participant "GitHub API" as GHAPI
participant "Git" as GIT
participant "OSV API" as OSV
participant "OWASP ZAP" as ZAP
participant "CLI Scanner" as CLI
participant "EmailService" as EMAIL

== Connexion ==
U -> UI: saisir email + mot de passe
UI -> AC: POST /auth/login
AC -> UM: charger user
UM -> DB: SELECT user
DB --> UM: user
AC -> AC: verifier password + status
alt TOTP active
    AC --> UI: totp_required + token
    U -> UI: saisir code TOTP
    UI -> TC: POST /auth/2fa/verify-login
    TC -> UM: charger secret
    UM -> DB: SELECT user
    DB --> UM: secret
    TC -> SMGR: create_refresh_session()
    SMGR -> DB: INSERT auth_token
    TC --> UI: access + refresh tokens
else TOTP inactive
    AC -> SMGR: create_refresh_session()
    SMGR -> DB: INSERT auth_token
    AC -> ALS: create_audit_log("login")
    ALS -> DB: INSERT audit_log
    AC --> UI: access + refresh tokens
end
UI --> U: session ouverte

== Projets (CRUD) ==
U -> UI: creer projet
UI -> PC: POST /projects
PC -> PS: create_project(dto, user)
PS -> PM: new Project
PM -> DB: INSERT project
DB --> PM: id
PC --> UI: projet cree

== Integrations GitHub OAuth ==
U -> UI: connecter GitHub
UI -> IC: GET /integrations/github/oauth/start
IC --> UI: authorize_url + state
UI -> GHO: redirect + consent
GHO --> UI: code + state
UI -> IC: POST /integrations/github/oauth/exchange
IC -> GHAPI: POST /login/oauth/access_token
GHAPI --> IC: access_token
IC -> GR: upsert repo + token
GR -> DB: INSERT/UPDATE github_repository
DB --> GR: ok
IC --> UI: connected

== API Keys CLI ==
U -> UI: creer cle API
UI -> AKC: POST /auth/api-keys
AKC -> AKM: new api key
AKM -> DB: INSERT api_key
DB --> AKM: ok
AKC -> ALS: create_audit_log("api_key_created")
ALS -> DB: INSERT audit_log
AKC --> UI: plaintext key (once)

== Scan SAST/SCA GitHub ==
U -> UI: lancer scan
UI -> SC: POST /projects/{id}/scans (method=github)
SC -> PS: get_project_accessible()
PS -> PM: SELECT project
SC -> SCM: INSERT scan (pending)
SCM -> DB: INSERT scan
SC -> GR: upsert repo info
GR -> DB: UPDATE github_repository
SC -> CW: run_github_scan_job.apply_async
CW -> SCM: update job_state queued
SCM -> DB: UPDATE scan
CW -> GS: run_github_scan()
GS -> SCM: set status running
SCM -> DB: UPDATE scan
GS -> GIT: git clone repo
GIT --> GS: working tree
GS -> GS: run SAST + secrets rules
GS -> DS: scan_dependencies(lockfiles)
DS -> OSV: query batch
OSV --> DS: vulns
DS --> GS: dependency findings
GS -> SCM: save results_json + completed
SCM -> DB: UPDATE scan
GS -> RS: upsert_scan_risk_score()
RS -> RSM: INSERT/UPDATE risk_score
RSM -> DB: ok
GS -> VWS: sync_vulnerability_tasks_for_scan()
VWS -> VTM: UPSERT tasks
VTM -> DB: ok
GS -> WS: emit_scan_state_change

== Scan DAST ==
U -> UI: lancer DAST
UI -> DC: POST /dast/scan/start
DC -> SCM: INSERT scan (pending)
SCM -> DB: INSERT scan
DC -> CW: run_dast_scan_job.apply_async
CW -> DASTS: run_dast_scan_async()
DASTS -> ZAP: spider + ascan + alerts
ZAP --> DASTS: findings
CW -> SCM: save results_json + completed
SCM -> DB: UPDATE scan
CW -> RS: get_or_create_scan_risk_score()
RS -> RSM: INSERT/UPDATE
CW -> VWS: sync_vulnerability_tasks_for_scan()
VWS -> VTM: UPSERT tasks
CW -> WS: emit_scan_state_change

== Scan CLI local ==
CLI -> SC: POST /cli/scan (api key)
SC -> SCM: create scan + running
SCM -> DB: INSERT/UPDATE scan
SC -> RS: get_or_create_scan_risk_score()
RS -> RSM: INSERT/UPDATE
SC -> VWS: sync_vulnerability_tasks_for_scan()
VWS -> VTM: UPSERT tasks
SC -> NS: create_notification(scan_complete)
NS -> DB: INSERT notification
NS -> WS: emit_notification_created

== Workflow securite ==
SEC -> UI: ouvrir workflow vulnerabilities
UI -> WC: GET /projects/{id}/security/vulnerability-tasks
WC -> PS: get_project_accessible()
PS -> PM: SELECT project
WC -> VWS: sync_vulnerability_tasks_for_scan()
VWS -> VTM: UPSERT tasks
VTM -> DB: ok
WC --> UI: tasks + assignees

SEC -> UI: assigner / changer statut
UI -> WC: PATCH /projects/{id}/security/vulnerability-tasks/{task_id}
WC -> VTM: update task + status
VTM -> DB: UPDATE task
WC -> NS: create_notification(assignee, security)
NS -> DB: INSERT notification
NS -> WS: emit_notification_created

== Dashboard ==
U -> UI: ouvrir dashboard
UI -> DBC: GET /dashboard/stats
DBC -> SSC: get_scan_summary()
DBC -> RS: read risk score
RS -> RSM: SELECT risk_score
RSM -> DB: ok
DBC --> UI: metrics + risk overview

== Role request (optionnel) ==
U -> UI: demander role
UI -> AC: POST /auth/request-role
AC -> UM: set requested_role_id
UM -> DB: UPDATE user
AC -> ALS: create_audit_log("role_request")
ALS -> DB: INSERT audit_log
AC -> NS: create_notification(admins + user)
NS -> DB: INSERT notification
NS -> WS: emit_notification_created
AC -> EMAIL: notify_admin_role_request + notify_user_role_request_received
AC --> UI: status pending
@enduml
