@startuml
title Workflow global - Connexion vers toutes les features

start
:Accueil;
:Login / Sign up;
if (Nouveau utilisateur?) then (oui)
  :Creer compte;
  :Envoyer email verification;
  :Verifier email (lien); 
endif
:Se connecter;
if (2FA active?) then (oui)
  :Entrer code TOTP;
endif
:Session ouverte;

partition "Navigation principale" {
  :Ouvrir dashboard;
  if (Choisir feature?) then (Projets)
    :Creer / gerer projet;
    :Ajouter membres + roles projet;
  elseif (Integrations)
    :Connecter GitHub OAuth;
  elseif (API keys)
    :Creer cle API CLI;
  elseif (Scans)
    if (Type de scan?) then (GitHub SAST/SCA)
      :Lancer scan GitHub;
      :Analyser code + dependances (OSV);
    elseif (DAST)
      :Lancer DAST (ZAP);
    else (CLI local)
      :Lancer scan CLI local;
      :Uploader resultats;
    endif
    :Resultats + risk score;
    :Taches vulnerabilities creees;
  elseif (Workflow securite)
    :Voir taches vulnerabilities;
    :Assigner / changer statut;
    :Demander fixes ou rescan;
  elseif (Notifications)
    :Consulter notifications;
  else (Admin)
    :Gerer utilisateurs / roles;
  endif
}

if (Viewer demande role?) then (oui)
  :Demande role (Developer/Security Manager);
  :Admin approuve role;
  :Role mis a jour;
endif

stop
@enduml
