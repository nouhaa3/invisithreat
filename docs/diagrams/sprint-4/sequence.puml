@startuml
title Sprint 4 - DAST et orchestration (OWASP ZAP + Celery)
actor "Utilisateur" as U
boundary "IHM DAST" as UI
control "DastController" as DC
control "ProjectService" as PS
entity "ProjectModel" as PM
entity "ScanModel" as SM
database "Base de donnees" as DB
control "ScanProgressCache" as SPC
control "CeleryWorker" as CW
control "DastScannerService" as DS
control "ZAPHealthService" as ZHS
participant "OWASP ZAP" as ZAP
control "RiskScoreService" as RS
entity "RiskScoreModel" as RSM
control "VulnWorkflowService" as VWS
entity "VulnerabilityTaskModel" as VTM
control "SocketIOManager" as WS

U -> UI: lancer DAST
UI -> DC: POST /dast/scan/start
DC -> PS: get_project_accessible()
PS -> PM: charger project
PM -> DB: SELECT project
DB --> PM: project
DC -> SM: create Scan(pending, method=dast)
SM -> DB: INSERT scan
DB --> SM: scan id
DC -> SPC: set_scan_progress(pending)
DC -> CW: run_dast_scan_job.apply_async
CW -> SM: set job_id + job_state queued
SM -> DB: UPDATE scan
CW -> WS: emit_scan_state_change(queued)
DC --> UI: scan_id + job_id

CW -> SM: set status running
SM -> DB: UPDATE scan
CW -> WS: emit_scan_state_change(running)
CW -> DS: run_dast_scan_async(target_url, progress_cb)
DS -> ZHS: ensure_zap_running()
ZHS -> ZAP: GET /core/view/version
ZAP --> ZHS: ok
DS -> ZAP: spider.scan + status
loop progress
    DS -> CW: progress_cb(stage, spider, active)
    CW -> SPC: set_scan_progress(update)
    CW -> WS: emit_scan_progress_update
end
DS -> ZAP: ascan.scan + core.alerts
ZAP --> DS: alerts
DS --> CW: findings
CW -> SM: save results_json + status completed/failed
SM -> DB: UPDATE scan
CW -> RS: get_or_create_scan_risk_score()
RS -> RSM: INSERT/UPDATE
RSM -> DB: ok
CW -> VWS: sync_vulnerability_tasks_for_scan()
VWS -> VTM: UPSERT tasks
VTM -> DB: ok
CW -> WS: emit_scan_state_change(completed)

UI -> DC: GET /dast/scan/{id}/status
DC -> SPC: get_scan_progress()
DC -> SM: read scan status
SM -> DB: SELECT scan
DC --> UI: status + progress
@enduml
